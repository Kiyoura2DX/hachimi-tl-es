{
    "title": "Prologo",
    "text_block_list": [
        {
            "text": "Forja tu propio camino."
        },
        {
            "text": "¿Alcanzarás la corona?"
        },
        {
            "text": "¿O tomarás la placa de Agosto?"
        },
        {
            "text": "O quizás...\n¿Buscas un prestigio<n>aún mayor?"
        },
        {
            "text": "No hay un camino correcto.\nEl sendero es tuyo<n>para trazar."
        },
        {
            "text": "Al final te espera un grial de gloria\ncon un<n>espacio vaio para tu nombre."
        },
        {
            "text": "Pocos se atreven a soñar.\nMenos dan el<n>primer paso."
        },
        {
            "text": " "
        }
    ]
}